# Copy this file to android/keystore.properties and fill in your values to
# produce a SIGNED release APK / AAB. Generate a keystore with:
#
#   keytool -genkey -v -keystore nexus-weight.keystore \
#           -alias nexus -keyalg RSA -keysize 2048 -validity 10000
#
# Then reference it below (path is relative to the android/ folder):

storeFile=nexus-weight.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=nexus
keyPassword=YOUR_KEY_PASSWORD
