{
  "name": "placeholder-model-2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync android",
    "android:open": "npm run build && cap sync android && cap open android",
    "android:apk": "npm run build && cap sync android && cd android && ./gradlew assembleRelease",
    "android:apk:debug": "npm run build && cap sync android && cd android && ./gradlew assembleDebug",
    "android:aab": "npm run build && cap sync android && cd android && ./gradlew bundleRelease"
  },
